# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build artifacts (the widget Vite build emits these into Next.js's public/)
# Vercel rebuilds them on every deploy via the build command.
public/widget.js
public/widget.js.map

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# plan documents (private, not for public repo)
/Plan/

# supabase temp files
supabase/.temp/

# test scripts
scripts/test-*

# FFmpeg WASM core binaries (copied from @ffmpeg/core at install time)
public/ffmpeg/

# Brand assets (client-confidential — do not commit). The bare-directory
# form `public/brand/` would block git from descending into the dir at all,
# so use a glob + re-include pattern to ship the tryon-refs subfolder while
# still ignoring everything else under public/brand/.
public/brand/*
# …but DO ship the curated try-on reference images. They are public,
# non-confidential clean product photos used by the chatbot try-on flow.
!public/brand/tryon-refs/
!public/brand/tryon-refs/*.jpg
!public/brand/tryon-refs/*.png
!public/brand/tryon-refs/*.webp

# Internal planning + agent state. Keep on disk for our own reference;
# do not push to the public repo.
.planning/
.claude/

# Internal screenshots saved during Playwright QA at the repo root.
/phase*.png
/tryon-*.png
/coco-*.html

# Local scratch test scripts (Phase 10 helper)
/scripts/_test-*.mts
