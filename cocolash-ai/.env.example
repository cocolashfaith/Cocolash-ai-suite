# ===========================================
# CocoLash AI Image Generator - Environment
# ===========================================
# Copy this file to .env.local and fill in the values

# Google Gemini API Key (for AI image generation)
GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Authentication (simple password auth for M1-M2)
AUTH_PASSWORD=your_secure_password_here
AUTH_TOKEN=your_secure_token_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Upgrade 1: AI Caption & Publishing Engine ──────────────────

# OpenRouter API Key (for Claude 3.5 Sonnet via OpenAI-compatible SDK)
OPENROUTER_API_KEY=sk-or-your_openrouter_key_here

# Blotato API Key (for cross-platform social publishing)
BLOTATO_API_KEY=your_blotato_api_key_here

# Replicate API Token (for Nano Banana Pro image composition)
REPLICATE_API_TOKEN=r8_your_replicate_token_here

# ── Upgrade 1: AI UGC Video Creator ─────────────────────────────

# HeyGen API Key (for AI avatar video generation)
HEYGEN_API_KEY=your_heygen_api_key_here

# Cloudinary Configuration (for video hosting and processing)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# ElevenLabs API Key (for AI text-to-speech voices)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ── Milestone 3: Seedance 2.0 UGC Video Pipeline ────────────────

# Enhancor.ai API Key (for Seedance 2.0 Full Access video generation)
ENHANCOR_API_KEY=your_enhancor_api_key_here
# Optional override; defaults to Enhancor production Full Access endpoint
ENHANCOR_API_BASE_URL=https://apireq.enhancor.ai/api/enhancor-ugc-full-access/v1
# Optional public callback URL; defaults to NEXT_PUBLIC_APP_URL/api/seedance/webhook
ENHANCOR_WEBHOOK_URL=
# Optional webhook token; required only when using app webhook callbacks
ENHANCOR_WEBHOOK_SECRET=

# Legacy Kie.ai key (unused after Enhancor migration; kept only for rollback context)
KIE_AI_API_KEY=your_kie_ai_api_key_here

# ── Shotstack (cloud video caption burning) ──────────────────────

# Shotstack API Key (for server-side caption rendering)
SHOTSTACK_API_KEY=your_shotstack_api_key_here
# Shotstack environment: "stage" (sandbox/free) or "v1" (production)
SHOTSTACK_ENV=stage

# ── Milestone v3.0: AI Sales Assistant + Virtual Try-On ─────────

# OpenAI API Key (for embeddings: text-embedding-3-small).
# Distinct from OPENROUTER_API_KEY which is used for Claude chat completions.
OPENAI_API_KEY=sk-your_openai_api_key_here

# Default daily cost cap for the chatbot (USD). Admin can override per-store.
CHATBOT_DAILY_CAP_USD_DEFAULT=50

# Shopify Storefront API (Phase 4)
# SHOPIFY_STOREFRONT_API_TOKEN accepts EITHER token type:
#   • PRIVATE token (recommended) — starts with "shpat_". Server-to-server,
#     better rate limits, never share. Header: Shopify-Storefront-Private-Token.
#   • PUBLIC token (also works) — long hex string. Header: X-Shopify-Storefront-Access-Token.
# The client auto-detects by prefix. Generate either from the Headless app:
#   Shopify Admin → Apps → Headless → <storefront> → Manage → Storefront API.
SHOPIFY_STORE_DOMAIN=cocolash.myshopify.com
SHOPIFY_STOREFRONT_API_TOKEN=your_shopify_storefront_token_here
SHOPIFY_STOREFRONT_API_VERSION=2025-01

# Shopify Custom App + App Proxy (Phase 8)
SHOPIFY_APP_API_KEY=
SHOPIFY_APP_API_SECRET=
SHOPIFY_APP_PROXY_PREFIX=/apps/cocolash-chat
SHOPIFY_WEBHOOK_SECRET=

# Support inbox for chatbot escalations (Phase 5)
CHATBOT_SUPPORT_EMAIL=support@cocolash.com

# Lead-capture email transport (Phase 5)
# When RESEND_API_KEY is unset OR LEAD_EMAIL_DRY_RUN=true, lead emails are
# logged to stdout and not sent. Resend is the lowest-friction Vercel-native
# option; alternatives like Postmark or AWS SES can swap into lib/chat/notify.ts.
RESEND_API_KEY=re_your_resend_api_key_here
LEAD_EMAIL_FROM=leads@cocolash.com
LEAD_EMAIL_DRY_RUN=false
